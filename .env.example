# ── Stellar Network ─────────────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# ── Admin Keys ──────────────────────────────────────────────────────────────────
# Generate with: stellar keys generate --global admin && stellar keys address admin
ADMIN_SECRET_KEY=

# ── Deployed Contract IDs (filled after deploy) ─────────────────────────────────
LUMINA_CORE_CONTRACT_ID=
NULLIFIER_REGISTRY_CONTRACT_ID=
RISK_ORACLE_CONTRACT_ID=
LIQUIDITY_POOLS_CONTRACT_ID=

# ── ZK Proving (Bonsai) ──────────────────────────────────────────────────────────
# Get from https://bonsai.xyz
BONSAI_API_KEY=
BONSAI_API_URL=https://api.bonsai.xyz

# ── RISC Zero Guest Image ID ─────────────────────────────────────────────────────
# Printed by: cd zk-prover && cargo build --release 2>&1 | grep "image_id"
ZK_GUEST_IMAGE_ID=

# ── Xero Integration ─────────────────────────────────────────────────────────────
# Create app at https://developer.xero.com/app/manage
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:4000/auth/xero/callback

# ── Backend Server ───────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Frontend ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_STELLAR_NETWORK=testnet
